# Server
PORT=5001

# PostgreSQL / Supabase (required for auth and map data)
# Local:
#   DATABASE_URL=postgresql://user:password@localhost:5432/lemontree
# Supabase: use the connection string from Project Settings → Database (URI, include your DB password)
#   DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# JWT secret (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# MAKE A .env file in backend directory and put env vars there
